        "ui_schema": {
            "displayString": "$config.app().APP_DISPLAY_NAME",
            "hidden": "$config.app().hidden:boolean:false:boolean:false",
            "position": "$config.app().dv_app_position:number:100",
            "icon": null,
            "colour": null,
            "defaultOpen": false,
            "type": "uiApplication",
            "name": "$config.app().APP_KEY",
            "children": {
                "link_state": {
                    "name": "link_state",
                    "type": "uiVariable",
                    "displayString": "Link State",
                    "showActivity": true,
                    "position": 51,
                    "hidden": false,
                    "varType": "string",
                    "currentValue": "$tag.app().link_state:string:\"disconnected\""
                },
                "temperature": {
                    "name": "temperature",
                    "type": "uiVariable",
                    "displayString": "Temperature",
                    "showActivity": true,
                    "position": 52,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().temperature:number:0",
                    "decPrecision": 1,
                    "ranges": [
                        {
                            "min": -20,
                            "max": 10,
                            "colour": "blue",
                            "show_on_graph": true,
                            "label": "Cold"
                        },
                        {
                            "min": 10,
                            "max": 60,
                            "colour": "green",
                            "show_on_graph": true,
                            "label": "Normal"
                        },
                        {
                            "min": 60,
                            "max": 120,
                            "colour": "red",
                            "show_on_graph": true,
                            "label": "Hot"
                        }
                    ]
                },
                "velocity_peak": {
                    "name": "velocity_peak",
                    "type": "uiVariable",
                    "displayString": "Peak Velocity (mm/s)",
                    "showActivity": true,
                    "position": 53,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().velocity_peak:number:0",
                    "decPrecision": 2,
                    "ranges": [
                        {
                            "min": 0,
                            "max": 2.8,
                            "colour": "green",
                            "show_on_graph": true,
                            "label": "Good"
                        },
                        {
                            "min": 2.8,
                            "max": 7.1,
                            "colour": "yellow",
                            "show_on_graph": true,
                            "label": "Caution"
                        },
                        {
                            "min": 7.1,
                            "max": 18.0,
                            "colour": "orange",
                            "show_on_graph": true,
                            "label": "Warning"
                        },
                        {
                            "min": 18.0,
                            "max": 100.0,
                            "colour": "red",
                            "show_on_graph": true,
                            "label": "Alarm"
                        }
                    ]
                },
                "displacement_peak": {
                    "name": "displacement_peak",
                    "type": "uiVariable",
                    "displayString": "Peak Displacement (um)",
                    "showActivity": true,
                    "position": 54,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().displacement_peak:number:0",
                    "decPrecision": 0
                },
                "frequency_dominant": {
                    "name": "frequency_dominant",
                    "type": "uiVariable",
                    "displayString": "Dominant Frequency (Hz)",
                    "showActivity": true,
                    "position": 55,
                    "hidden": false,
                    "varType": "float",
                    "currentValue": "$tag.app().frequency_dominant:number:0",
                    "decPrecision": 1
                }
            }
